# Git attributes for RoutiQ AIR project

# Text files
*.md text eol=lf
*.py text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files
*.pkl binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.csv binary

# Large files - use Git LFS if needed
*.csv filter=lfs diff=lfs merge=lfs -text
*.pkl filter=lfs diff=lfs merge=lfs -text

# End of line normalization for all text files
* text=auto eol=lf
